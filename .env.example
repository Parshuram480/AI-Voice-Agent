# =============================================================================
# Voice-Agent Environment Configuration
# Copy this file to .env and fill in your actual values.
# =============================================================================

# --- Twilio ---
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+15551234567

# --- Groq AI ---
GROQ_API_KEY=your_groq_api_key_here

# --- PostgreSQL Database ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=voice_agent
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# --- Server ---
# Public URL for Twilio callbacks (e.g. ngrok URL)
SERVER_HOST=https://your-ngrok-url.ngrok-free.app
# Local server port
SERVER_PORT=8000

# --- Conversation Settings ---
SESSION_TTL_SECONDS=900
SESSION_MAX_TURNS=10
SESSION_MAX_RETRIES=2
CONTINUATION_DEBOUNCE_MS=300

# --- Controlled LLM Rephrase ---
LLM_REPHRASE=false
LLM_REPHRASE_MAX_TOKENS=96
LLM_REPHRASE_TEMPERATURE=0.2

# --- Voice Activity Detection (VAD) ---
# Silence duration (ms) before utterance is finalized
VAD_SILENCE_MS=800
# Minimum speech duration (ms) to consider valid
MIN_SPEECH_MS=250
# Maximum utterance duration (ms) before forced finalization
MAX_UTTERANCE_MS=30000

# --- Streaming Pipeline Tuning ---
# RMS threshold below which audio is considered silence (0-32768)
SILENCE_THRESHOLD=500
SILENCE_DURATION_MS=1500
TWILIO_STREAM_AUDIO_OUT=true
# Early STT chunk — seconds of audio to send for early transcription
STT_EARLY_CHUNK_SECONDS=1.0
# TTS response cache size
TTS_CACHE_SIZE=100
# VAD aggressiveness (1=least aggressive, 3=most aggressive)
VAD_AGGRESSIVENESS=3

# --- Pipeline Mode ---
# cascade = existing STT → LLM → TTS pipeline (Groq/Deepgram/Cartesia)
# multimodal = Gemini Live API (single model, lowest latency)
PIPELINE_MODE=cascade

# --- Gemini Multimodal Config (only used when PIPELINE_MODE=multimodal) ---
GOOGLE_API_KEY=
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
GEMINI_VOICE=Puck

# --- Models & Voices ---
STT_MODEL=whisper-large-v3-turbo
LLM_MODEL=llama-3.1-8b-instant

# Dual LLM Orchestration Configuration
GROQ_LLM1_API_KEY=
GROQ_LLM2_API_KEY=
LLM1_MODEL=llama-3.1-8b-instant
LLM2_MODEL=llama-3.1-8b-instant

# Switch between "groq" and "openai"
LLM_PROVIDER=groq
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=

TTS_PROVIDER=cartesia
TTS_MODEL=canopylabs/orpheus-v1-english
TTS_VOICE=hannah

CARTESIA_API_KEY=
CARTESIA_VOICE_ID=

# --- Silero Neural VAD (Optional, better noise rejection) ---
# Set to true to use Silero VAD instead of WebRTC VAD
# Requires: pip install silero-vad-lite
USE_SILERO_VAD=false
# Speech probability threshold (0.0-1.0, higher = stricter)
SILERO_THRESHOLD=0.5

# --- Deepgram STT (Optional, alternative to Groq Whisper) ---
# Set to true and provide API key to use Deepgram
# Falls back to Groq Whisper if key is exhausted or Deepgram fails
# Requires: pip install deepgram-sdk
USE_DEEPGRAM=false
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3

# --- Filler Words (Natural wait-masking) ---
# When true, sends short filler phrases ("Let me check...", "Got it.")
# while the pipeline processes, making the wait feel natural
USE_FILLER_WORDS=true

# --- STT Configuration ---
# groq or deepgram
STT_PROVIDER=groq
DEEPGRAM_API_KEY=

# --- Background Summarization ---
GROQ_SUMMARY_API_KEY=
SUMMARY_MODEL=llama-3.1-8b-instant

# LangSmith Observability
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=voice_agent

MY_CELL_PHONE=
NGROK_URL=

# --- LiveKit WebRTC ---
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_api_key_here
LIVEKIT_API_SECRET=your_api_secret_here

